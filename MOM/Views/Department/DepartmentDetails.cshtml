@model MOM.Models.Department

@{
    ViewData["Title"] = "Department Details";
}

<div class="pagetitle mb-4">
    <h1 class="mb-1">Department Details</h1>
    <p class="text-muted mb-0">
        View detailed information about this department
    </p>
</div>

<section class="section">
    <div class="row">

        <!-- LEFT: Department Information -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-building"></i> Department Information
                    </h5>

                    <div>
                        <a asp-action="DepartmentAddEdit"
                           asp-route-id="@Model.DepartmentID"
                           class="btn btn-sm btn-light">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <small class="text-muted">Department ID</small>
                            <div class="fw-semibold">@Model.DepartmentID</div>
                        </div>

                        <div class="col-md-6">
                            <small class="text-muted">Department Name</small>
                            <div class="fw-semibold">@Model.DepartmentName</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <small class="text-muted">Created Date</small>
                            <div>@Model.Created.ToString("yyyy-MM-dd HH:mm")</div>
                        </div>

                        <div class="col-md-6">
                            <small class="text-muted">Last Modified</small>
                            <div>@Model.Modified.ToString("yyyy-MM-dd HH:mm")</div>
                        </div>
                    </div>

           
                </div>
            </div>
        </div>

        <!-- RIGHT: Statistics -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light">
                    <strong>Department Statistics</strong>
                </div>

                <div class="card-body text-center">
                    <div class="row">
                        <div class="col-6 mb-3">
                            <h3 class="text-primary">3</h3>
                            <small class="text-muted">Total Staff</small>
                        </div>

                        <div class="col-6 mb-3">
                            <h3 class="text-success">2</h3>
                            <small class="text-muted">Meetings</small>
                        </div>

                        <div class="col-6">
                            <h3 class="text-warning">1</h3>
                            <small class="text-muted">Upcoming</small>
                        </div>

                        <div class="col-6">
                            <h3 class="text-danger">0</h3>
                            <small class="text-muted">Cancelled</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <strong>Quick Actions</strong>
                </div>

                <div class="card-body d-grid gap-2">
                    <a asp-controller="Staff"
                       asp-action="StaffList"
                       asp-route-departmentId="@Model.DepartmentID"
                       class="btn btn-outline-primary">
                        <i class="bi bi-people"></i> View Staff Members
                    </a>

                    <a asp-controller="Staff"
                       asp-action="StaffAddEdit"
                       asp-route-departmentId="@Model.DepartmentID"
                       class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Add Staff Member
                    </a>
                </div>
            </div>
        </div>

    </div>
</section>
