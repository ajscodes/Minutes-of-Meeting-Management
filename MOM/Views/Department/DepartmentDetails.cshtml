@model MOM.Models.Department

@{
    ViewData["Title"] = "Department Details";
}

<div class="pagetitle mb-4">
    <h1 class="fw-bold">@ViewData["Title"]</h1>
    <p class="text-muted mb-0">
        View detailed information about this department
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="DepartmentList">Departments</a>
            </li>
            <li class="breadcrumb-item active">Details</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">

        <!-- LEFT: Department Information -->
        <div class="col-lg-8">
            <div class="mom-card mb-4">
                <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-building"></i>
                        Department Information
                    </div>
                    
                    <a asp-action="DepartmentAddEdit"
                       asp-route-id="@Model.DepartmentID"
                       class="mom-btn-outline"
                       style="padding: 6px 12px; font-size: 13px;">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                </div>

                <div class="mom-card-body">
                    <div class="mom-info-grid">
                        
                        <div class="mom-label">Department Name</div>
                        <div class="mom-value text-primary fs-5">@Model.DepartmentName</div>

                        <div class="mom-label">Department ID</div>
                        <div class="mom-value">#@Model.DepartmentID</div>

                        <div class="mom-label">Created Date</div>
                        <div class="mom-value">
                            @Model.Created.ToString("dd MMM yyyy")
                            <small class="text-muted ms-2">@Model.Created.ToString("hh:mm tt")</small>
                        </div>

                        <div class="mom-label">Last Modified</div>
                        <div class="mom-value">
                            @Model.Modified.ToString("dd MMM yyyy")
                            <small class="text-muted ms-2">@Model.Modified.ToString("hh:mm tt")</small>
                        </div>

                    </div>
                </div>
            </div>
            
            <!-- Recent Activity (Placeholder for future) -->
            <div class="mom-card">
                 <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-clock-history"></i>
                        Recent Activity
                    </div>
                </div>
                <div class="mom-card-body">
                    <div class="text-muted text-center py-4">
                        <i class="bi bi-info-circle mb-2 d-block fs-4"></i>
                        No recent activity found.
                    </div>
                </div>
            </div>

        </div>

        <!-- RIGHT: Statistics & Actions -->
        <div class="col-lg-4">
            
            <!-- Statistics -->
            <div class="mom-card mb-4">
                <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-bar-chart"></i>
                        Statistics
                    </div>
                </div>

                <div class="mom-card-body">
                    <div class="row text-center">
                        <div class="col-6 mb-4">
                            <div class="mom-stat-value text-primary">3</div>
                            <div class="mom-stat-label">Total Staff</div>
                        </div>

                        <div class="col-6 mb-4">
                            <div class="mom-stat-value text-success">2</div>
                            <div class="mom-stat-label">Meetings</div>
                        </div>

                        <div class="col-6">
                            <div class="mom-stat-value text-warning">1</div>
                            <div class="mom-stat-label">Upcoming</div>
                        </div>

                        <div class="col-6">
                            <div class="mom-stat-value text-danger">0</div>
                            <div class="mom-stat-label">Cancelled</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="mom-card">
                <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-lightning-charge"></i>
                        Quick Actions
                    </div>
                </div>

                <div class="mom-card-body d-grid gap-3"> 
                    <a asp-controller="Staff"
                       asp-action="StaffList"
                       asp-route-departmentId="@Model.DepartmentID"
                       class="mom-btn-outline w-100 justify-content-center">
                        <i class="bi bi-people"></i> View Staff Members
                    </a>

                    <a asp-controller="Staff"
                       asp-action="StaffAddEdit"
                       asp-route-departmentId="@Model.DepartmentID"
                       class="mom-btn-primary w-100 justify-content-center">
                        <i class="bi bi-person-plus"></i> Add Staff Member
                    </a>
                </div>
            </div>
            
        </div>

    </div>
</section>
