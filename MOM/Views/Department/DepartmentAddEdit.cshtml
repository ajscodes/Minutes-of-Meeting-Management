@model MOM.Models.Department

@{
    ViewData["Title"] = Model.DepartmentID == 0 ? "Add Department" : "Edit Department";
}

<div class="pagetitle">
    <h1>@ViewData["Title"]</h1>
    <p>Create or update department</p>
</div>

<section class="section">
    <div class="mom-form-wrapper">

        <div class="mom-form-card">

            <div class="mom-form-header">
                <i class="bi bi-building"></i>
                @ViewData["Title"]
            </div>

            <form asp-action="DepartmentAddEdit" method="post">
                <input type="hidden" asp-for="DepartmentID" />

                <div class="mom-form-body">

                    <div class="mb-4">
                        <label asp-for="DepartmentName" class="mom-label">Department Name <span class="text-danger">*</span></label>
                        <input asp-for="DepartmentName"
                               class="mom-input"
                               placeholder="Enter department name" />
                        <span asp-validation-for="DepartmentName" class="text-danger small"></span>
                        <div class="mom-hint">
                            e.g. Human Resources, IT, Finance
                        </div>
                    </div>

                </div>

                <div class="mom-form-footer">
                    <a asp-action="DepartmentList"
                       class="mom-btn-outline">
                        ? Back to List
                    </a>

                    <button type="submit"
                            class="mom-btn-primary">
                        <i class="bi bi-check-circle"></i> Save Department
                    </button>
                </div>

            </form>

        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
