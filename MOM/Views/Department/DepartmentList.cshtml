@model List<MOM.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="pagetitle d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Departments</h1>
        <p class="text-muted mb-0">
            Manage organizational departments and their details
        </p>
    </div>

    <a asp-controller="Department"
       asp-action="DepartmentAddEdit"
       class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Department
    </a>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <strong>Departments List</strong>
                </div>

                <div class="card-body">

                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-info text-center mb-0">
                            No departments found.
                        </div>
                    }
                    else
                    {
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:5%">#</th>
                                    <th>Department Name</th>
                                    <th style="width:20%">Created Date</th>
                                    <th style="width:20%">Modified Date</th>
                                    <th style="width:15%" class="text-center">Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int srNo = 1;
                                }

                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@srNo</td>

                                        <td class="fw-semibold">
                                            @item.DepartmentName
                                        </td>

                                        <td>
                                            @item.Created.ToString("yyyy-MM-dd")
                                        </td>

                                        <td>
                                            @item.Modified.ToString("yyyy-MM-dd HH:mm")
                                        </td>

                                        <td class="text-center">
                                            <a asp-action="DepartmentAddEdit"
                                               asp-route-id="@item.DepartmentID"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            <a asp-action="DepartmentDetails"
                                               asp-route-id="@item.DepartmentID"
                                               class="btn btn-sm btn-outline-secondary"
                                               title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>

                                    srNo++;
                                }
                            </tbody>
                        </table>
                    }

                </div>
            </div>

        </div>
    </div>
</section>
