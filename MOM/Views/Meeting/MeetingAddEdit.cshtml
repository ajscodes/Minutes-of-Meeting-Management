@model MOM.Models.Meeting

@{
    bool isEdit = Model.MeetingID > 0;
    ViewData["Title"] = isEdit ? "Edit Meeting" : "Schedule Meeting";
}

<div class="pagetitle">
    <h1>@ViewData["Title"]</h1>
    <p>@(isEdit ? "Update meeting details" : "Schedule a new meeting")</p>
</div>

<section class="section">
    <div class="mom-form-wrapper">

        <div class="mom-form-card">

            <div class="mom-form-header">
                <i class="bi bi-calendar-event"></i>
                @ViewData["Title"]
            </div>

            <form asp-action="MeetingAddEdit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="MeetingID" />
                <input type="hidden" asp-for="DocumentPath" />

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mx-4 mt-3 mb-0"></div>

                <div class="mom-form-body">

                    <div class="row g-4">

                        <!-- Date & Time -->
                        <div class="col-md-6">
                            <label asp-for="MeetingDate" class="mom-label">Date & Time <span class="text-danger">*</span></label>
                            <input asp-for="MeetingDate"
                                   class="mom-input"
                                   type="datetime-local" />
                            <span asp-validation-for="MeetingDate" class="text-danger small"></span>
                        </div>

                        <!-- Meeting Type -->
                        <div class="col-md-6">
                            <label asp-for="MeetingTypeID" class="mom-label">Meeting Type <span class="text-danger">*</span></label>
                            <select asp-for="MeetingTypeID"
                                    asp-items="ViewBag.MeetingTypes"
                                    class="mom-input"
                                    required>
                                <option value="">-- Select Meeting Type --</option>
                            </select>
                            <span asp-validation-for="MeetingTypeID" class="text-danger small"></span>
                        </div>

                        <!-- Department -->
                        <div class="col-md-6">
                            <label asp-for="DepartmentID" class="mom-label">Department <span class="text-danger">*</span></label>
                            <select asp-for="DepartmentID"
                                    asp-items="ViewBag.Departments"
                                    class="mom-input"
                                    required>
                                <option value="">-- Select Department --</option>
                            </select>
                            <span asp-validation-for="DepartmentID" class="text-danger small"></span>
                        </div>

                        <!-- Venue -->
                        <div class="col-md-6">
                            <label asp-for="MeetingVenueID" class="mom-label">Meeting Venue <span class="text-danger">*</span></label>
                            <select asp-for="MeetingVenueID"
                                    asp-items="ViewBag.MeetingVenues"
                                    class="mom-input"
                                    required>
                                <option value="">-- Select Venue --</option>
                            </select>
                            <span asp-validation-for="MeetingVenueID" class="text-danger small"></span>
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            <label asp-for="MeetingDescription" class="mom-label">Description</label>
                            <textarea asp-for="MeetingDescription"
                                      class="mom-textarea"
                                      rows="3"
                                      placeholder="Meeting agenda and details"></textarea>
                            <span asp-validation-for="MeetingDescription" class="text-danger small"></span>
                        </div>

                        <!-- Document Path -->
                        <div class="col-12">
                            <label asp-for="DocumentFile" class="mom-label">Document File</label>
                            <input type="file" asp-for="DocumentFile" class="mom-input" />
                            <span asp-validation-for="DocumentFile" class="text-danger small"></span>

                            @if (!string.IsNullOrEmpty(Model?.DocumentPath))
                            {
                                <div class="mt-2">
                                    <small class="text-muted">Current File: <a href="@Model.DocumentPath" target="_blank">View File</a></small>
                                </div>
                            }
                        </div>

                        <!-- Edit Mode Only: Cancellation -->
                        @if (isEdit)
                        {
                            <div class="col-12">
                                <hr class="my-2" />
                            </div>

                            <div class="col-12">
                                <div class="form-check">
                                    <input asp-for="IsCancelled" class="form-check-input" />
                                    <label asp-for="IsCancelled" class="form-check-label fw-bold">
                                        Cancel this meeting?
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CancellationDateTime" class="mom-label">Cancellation Date</label>
                                <input asp-for="CancellationDateTime" class="mom-input" type="datetime-local" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CancellationReason" class="mom-label">Reason</label>
                                <input asp-for="CancellationReason" class="mom-input" placeholder="Reason for cancellation" />
                            </div>
                        }

                    </div>

                </div>

                <div class="mom-form-footer">
                    <a asp-action="MeetingList"
                       class="mom-btn-outline">
                        ? Back to Meetings
                    </a>

                    <button type="submit"
                            class="mom-btn-primary">
                        <i class="bi bi-check-circle"></i> @(isEdit ? "Update Meeting" : "Schedule Meeting")
                    </button>
                </div>

            </form>

        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
