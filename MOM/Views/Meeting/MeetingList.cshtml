@model List<MOM.Models.Meeting>

@{
    ViewData["Title"] = "Meetings Management";
}

<!-- PAGE TITLE -->
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Meetings Management</h1>
    <p class="text-muted mb-2">
        Schedule and manage organizational meetings
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active">Meetings</li>
        </ol>
    </nav>
</div>

<section class="section">

    <!-- TOP ACTION BAR -->
    <div class="d-flex justify-content-end gap-2 mb-4">
        <a asp-action="MeetingAddEdit" class="mom-btn-primary">
            <i class="bi bi-calendar-plus"></i>
            Schedule Meeting
        </a>

        <a href="#" class="mom-btn-outline">
            <i class="bi bi-file-earmark-excel"></i>
            Export
        </a>
    </div>

    <!-- FILTER & SEARCH -->
    <div class="mom-card mb-4">
        <div class="mom-card-body py-3">
            <form method="get">
                <div class="row g-3">

                    <!-- FILTERS -->
                    <div class="col-md-3">
                        <label class="mom-label">Meeting Type</label>
                        <select class="mom-select">
                            <option value="">All Types</option>
                            <option value="1">Board Meeting</option>
                            <option value="2">Review</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="mom-label">Department</label>
                        <select class="mom-select">
                            <option value="">All Departments</option>
                            <option value="1">HR</option>
                            <option value="2">IT</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="mom-label">Start Date</label>
                        <input type="date" class="mom-input" />
                    </div>
                    
                     <div class="col-md-3">
                        <label class="mom-label">End Date</label>
                        <input type="date" class="mom-input" />
                    </div>

                    <!-- SEARCH & ACTIONS -->
                    <div class="col-md-9">
                        <div class="mom-search-input">
                            <i class="bi bi-search"></i>
                            <input type="text"
                                   class="form-control"
                                   placeholder="Search meeting description..." />
                        </div>
                    </div>

                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="mom-btn-primary w-100">
                            Apply
                        </button>
                        <a asp-action="MeetingList" class="mom-btn-outline w-100">
                            Clear
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>


    <!-- MEETING LIST -->
    <div class="mom-card">
        <div class="mom-card-header d-flex justify-content-between align-items-center">
            <div class="mom-card-title">
                <i class="bi bi-calendar-event"></i>
                Scheduled Meetings
            </div>

            <span class="badge bg-light text-dark">
                Total: @(Model?.Count ?? 0)
            </span>
        </div>

        <div class="mom-card-body p-0">
            <table class="table mom-table align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:50px">#</th>
                        <th style="width:140px">Date</th>
                        <th>Meeting Type</th>
                        <th>Description</th>
                        <th>Department</th>
                        <th>Venue</th>
                        <th>Status</th>
                        <th style="width:140px" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int index = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">@index</td>

                                <!-- Date -->
                                <td>
                                    <div class="fw-semibold text-dark">
                                        @item.MeetingDate.ToString("MMM dd, yyyy")
                                    </div>
                                    <div class="text-muted small">
                                        @item.MeetingDate.ToString("hh:mm tt")
                                    </div>
                                </td>

                                <!-- Type -->
                                <td>                             
                                    <div class="fw-semibold text-primary">
                                        @item.MeetingType.MeetingTypeName
                                    </div>
                                </td>

                                <!-- Description -->
                                <td class="text-muted text-truncate" style="max-width: 200px;">
                                    @item.MeetingDescription
                                </td>

                                <!-- Department -->
                                <td>@item.Department.DepartmentName</td>

                                <!-- Venue -->
                                <td>@item.MeetingVenue.MeetingVenueName</td>

                                <!-- Status -->
                                <td>
                                    @if (item.IsCancelled)
                                    {
                                        <span class="badge bg-danger">Cancelled</span>
                                    }
                                    else if (item.MeetingDate > DateTime.Now)
                                    {
                                        <span class="badge bg-primary">Upcoming</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                </td>

                                <!-- Actions -->
                                <td class="text-center">
                                    <div class="d-inline-flex gap-2">
                                        <!-- Edit -->
                                        <a asp-action="MeetingAddEdit"
                                           asp-route-id="@item.MeetingID"
                                           class="mom-icon-btn text-warning"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <!-- Cancel -->
                                        @if (!item.IsCancelled)
                                        {
                                            <a asp-action="CancelMeeting"
                                               asp-route-id="@item.MeetingID"
                                               class="mom-icon-btn text-primary"
                                               title="Cancel Meeting"
                                               onclick="return confirm('Are you sure you want to cancel this meeting?');">
                                                <i class="bi bi-x-circle"></i>
                                            </a>
                                        }

                                        <!-- Delete -->
                                        <a asp-action="DeleteMeeting"
                                           asp-route-id="@item.MeetingID"
                                           class="mom-icon-btn text-danger"
                                           title="Delete Record"
                                           onclick="return confirm('Are you sure you want to delete this record permanentely?');">
                                            <i class="bi bi-trash"></i>
                                        </a>

                                    </div>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8"
                                class="text-center text-muted py-4">
                                No meetings found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</section>
