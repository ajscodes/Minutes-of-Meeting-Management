@{
    ViewData["Title"] = "Meetings";
}

<!-- PAGE TITLE -->
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Meetings</h1>
    <p class="text-muted mb-2">
        View and manage all scheduled meetings
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active">Meetings</li>
        </ol>
    </nav>
</div>

<section class="section">

    <!-- TOP ACTION BAR -->
    <div class="d-flex justify-content-end gap-2 mb-4">
        <a asp-action="ScheduleMeeting" class="mom-btn-primary">
            <i class="bi bi-plus-circle"></i>
            Schedule Meeting
        </a>

        <a href="#" class="mom-btn-outline">
            <i class="bi bi-file-earmark-excel"></i>
            Export
        </a>
    </div>

    <!-- SEARCH -->
    <div class="mom-card mb-4">
        <div class="mom-card-body py-3">
            <form method="get">
                <div class="row g-2 align-items-center">

                    <div class="col-md-4">
                        <div class="mom-search-input">
                            <i class="bi bi-search"></i>
                            <input type="text"
                                   class="form-control"
                                   placeholder="Search meeting title..." />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <select class="form-select" style="height:44px;">
                            <option value="">All Meeting Types</option>
                            <option>Board Meeting</option>
                            <option>Client Meeting</option>
                            <option>Interview</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <input type="date"
                               class="form-control"
                               style="height:44px;" />
                    </div>

                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="mom-btn-primary w-100">
                            Search
                        </button>
                        <a asp-action="MeetingList" class="mom-btn-outline w-100">
                            Clear
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- MEETING LIST -->
    <div class="mom-card">
        <div class="mom-card-header d-flex justify-content-between align-items-center">
            <div class="mom-card-title">
                <i class="bi bi-calendar-event"></i>
                Meetings List
            </div>

            <span class="badge bg-light text-dark">
                Total Records: 3
            </span>
        </div>

        <div class="mom-card-body p-0">
            <table class="table mom-table align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Meeting Title</th>
                        <th>Meeting Type</th>
                        <th>Venue</th>
                        <th style="width:150px">Meeting Date</th>
                        <th style="width:120px">Status</th>
                        <th style="width:150px" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td class="text-muted">1</td>
                        <td class="fw-semibold text-primary">
                            Board Review Q1
                        </td>
                        <td>Board Meeting</td>
                        <td>Conference Room A</td>
                        <td>05 Feb 2026</td>
                        <td>
                            <span class="badge bg-success">
                                Upcoming
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-inline-flex gap-2">
                                <a href="#"
                                   class="mom-icon-btn text-info"
                                   title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="#"
                                   class="mom-icon-btn text-warning"
                                   title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="#"
                                   class="mom-icon-btn text-danger"
                                   title="Cancel">
                                    <i class="bi bi-x-circle"></i>
                                </a>
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td class="text-muted">2</td>
                        <td class="fw-semibold text-primary">
                            Client Requirement Discussion
                        </td>
                        <td>Client Meeting</td>
                        <td>Online (Zoom)</td>
                        <td>02 Feb 2026</td>
                        <td>
                            <span class="badge bg-info">
                                Completed
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-inline-flex gap-2">
                                <a href="#"
                                   class="mom-icon-btn text-info"
                                   title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="#"
                                   class="mom-icon-btn text-warning"
                                   title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td class="text-muted">3</td>
                        <td class="fw-semibold text-primary">
                            HR Interview Round
                        </td>
                        <td>Interview</td>
                        <td>Meeting Room 2</td>
                        <td>01 Feb 2026</td>
                        <td>
                            <span class="badge bg-secondary">
                                Cancelled
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-inline-flex gap-2">
                                <a href="#"
                                   class="mom-icon-btn text-info"
                                   title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</section>
