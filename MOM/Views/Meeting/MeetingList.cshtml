@model List<MOM.Models.Meeting>

@{
    ViewData["Title"] = "Meetings Management";
}

<div class="container-fluid">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Meetings Management</h2>
            <p class="text-muted mb-0">
                Schedule and manage organizational meetings
            </p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="ScheduleMeeting" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Schedule Meeting
            </a>

            <a href="#" class="btn btn-success">
                <i class="bi bi-file-earmark-excel"></i> Export
            </a>
        </div>
    </div>


    <!-- SEARCH & FILTERS -->
    <div class="card shadow-sm mb-4">
        <div class="card-header text-white"
             style="background: linear-gradient(90deg,#6a5acd,#8a2be2);">
            <i class="bi bi-funnel"></i> Search & Filters
        </div>

        <div class="card-body">
            <form method="get">
                <div class="row g-3">

                    <div class="col-md-3">
                        <label class="form-label">Meeting Type</label>
                        <select class="form-select">
                            <option value="">All Types</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Department</label>
                        <select class="form-select">
                            <option value="">All Departments</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Venue</label>
                        <select class="form-select">
                            <option value="">All Venues</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Search</label>
                        <input type="text"
                               class="form-control"
                               placeholder="Search meetings..." />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Start Date</label>
                        <input type="date" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">End Date</label>
                        <input type="date" class="form-control" />
                    </div>

                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary w-100">
                            Apply Filters
                        </button>
                        <a asp-action="MeetingList"
                           class="btn btn-outline-secondary w-100">
                            Clear
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>


    <!-- MEETINGS TABLE -->
    <div class="card shadow-sm border-0">
        <div class="card-header text-white fw-semibold"
             style="background: linear-gradient(90deg,#6a5acd,#8a2be2);">
            <i class="bi bi-calendar-event me-2"></i>
            Scheduled Meetings
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="bg-light text-muted small">
                        <tr>
                            <th style="width:60px;">#</th>
                            <th>Date & Time</th>
                            <th>Meeting Type</th>
                            <th>Description</th>
                            <th>Department</th>
                            <th>Venue</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int count = 1;

                            foreach (var item in Model)
                            {
                                <tr class="border-bottom"
                                    style="background-color:#f8f9fb;">

                                    <td class="fw-semibold text-muted">
                                        @count
                                    </td>

                                    <!-- Date & Time -->
                                    <td>
                                        <div class="fw-semibold">
                                            @item.MeetingDate.ToString("MMM dd, yyyy")
                                        </div>
                                        <div class="text-muted small">
                                            @item.MeetingDate.ToString("HH:mm")
                                        </div>
                                    </td>

                                    <!-- Meeting Type Badge -->
                                    <td>
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color:#17c0eb;">
                                              @item.MeetingType.MeetingTypeName
                                        </span>
                                    </td>

                                    <!-- Description -->
                                    <td class="text-muted">
                                        @item.MeetingDescription
                                    </td>

                                    <!-- Department -->
                                    <td>@item.Department.DepartmentName</td>

                                    <!-- Venue -->
                                    <td>@item.MeetingVenue.MeetingVenueName</td>

                                    <!-- Status -->
                                    <td>
                                        @if (item.IsCancelled)
                                        {
                                            <span class="badge rounded-pill px-3 py-2 bg-secondary">
                                                Cancelled
                                            </span>
                                        }
                                        else if (item.MeetingDate > DateTime.Now)
                                        {
                                            <span class="badge rounded-pill px-3 py-2 bg-success">
                                                Upcoming
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill px-3 py-2 bg-dark">
                                                Completed
                                            </span>
                                        }
                                    </td>

                                    <!-- Actions -->
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-3">

                                            <a asp-action="MeetingDetails"
                                               asp-route-id="@item.MeetingID"
                                               class="text-primary fs-5"
                                               title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            <a asp-action="MeetingAddEdit"
                                               asp-route-id="@item.MeetingID"
                                               class="text-warning fs-5"
                                               title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            @if (!item.IsCancelled)
                                            {
                                                <a asp-action="CancelMeeting"
                                                   asp-route-id="@item.MeetingID"
                                                   class="text-danger fs-5"
                                                   title="Cancel">
                                                    <i class="bi bi-x-circle"></i>
                                                </a>
                                            }

                                        </div>
                                    </td>

                                </tr>

                                count++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8"
                                    class="text-center text-muted py-4">
                                    No meetings found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>
