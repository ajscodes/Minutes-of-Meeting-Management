@model MOM.Models.Meeting

@{
    ViewData["Title"] = "Meeting Details";
}

<!-- PAGE TITLE -->
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Meeting Details</h1>
    <p class="text-muted mb-2">
        View complete information about the scheduled meeting
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Meeting" asp-action="MeetingList">Meetings</a>
            </li>
            <li class="breadcrumb-item active">Details</li>
        </ol>
    </nav>
</div>

<section class="section">

    <!-- TOP ACTION BAR -->
    <div class="d-flex justify-content-end gap-2 mb-4">
        <a asp-action="MeetingList" class="mom-btn-outline">
            <i class="bi bi-arrow-left"></i>
            Back to List
        </a>

        <a asp-action="MeetingAddEdit"
           asp-route-id="@Model.MeetingID"
           class="mom-btn-primary">
            <i class="bi bi-pencil"></i>
            Edit Meeting
        </a>
    </div>

    <!-- STATUS BANNER -->
    <div class="mom-card mb-4">
        <div class="mom-card-body py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    @if (Model.IsCancelled)
                    {
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:48px; height:48px; background-color:#fee2e2;">
                            <i class="bi bi-x-circle-fill text-danger fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold text-danger">Cancelled</h5>
                            <small class="text-muted">This meeting has been cancelled</small>
                        </div>
                    }
                    else if (Model.MeetingDate > DateTime.Now)
                    {
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:48px; height:48px; background-color:#dbeafe;">
                            <i class="bi bi-clock-fill text-primary fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold text-primary">Upcoming</h5>
                            <small class="text-muted">This meeting is scheduled for the future</small>
                        </div>
                    }
                    else
                    {
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:48px; height:48px; background-color:#dcfce7;">
                            <i class="bi bi-check-circle-fill text-success fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold text-success">Completed</h5>
                            <small class="text-muted">This meeting has been completed</small>
                        </div>
                    }
                </div>

                <div class="text-end">
                    <div class="text-muted small">Meeting ID</div>
                    <div class="fw-bold fs-5">#@Model.MeetingID</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- MEETING INFORMATION -->
        <div class="col-md-8">
            <div class="mom-card h-100">
                <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-info-circle"></i>
                        Meeting Information
                    </div>
                </div>
                <div class="mom-card-body">

                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <label class="mom-label mb-0">
                                <i class="bi bi-calendar-event me-1"></i> Date & Time
                            </label>
                        </div>
                        <div class="col-sm-8">
                            <span class="fw-semibold">
                                @Model.MeetingDate.ToString("dddd, MMMM dd, yyyy")
                            </span>
                            <br />
                            <span class="text-muted">
                                @Model.MeetingDate.ToString("hh:mm tt")
                            </span>
                        </div>
                    </div>
                    <hr class="my-2" />

                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <label class="mom-label mb-0">
                                <i class="bi bi-tags me-1"></i> Meeting Type
                            </label>
                        </div>
                        <div class="col-sm-8">
                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 fw-semibold">
                                @Model.MeetingType?.MeetingTypeName
                            </span>
                        </div>
                    </div>
                    <hr class="my-2" />

                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <label class="mom-label mb-0">
                                <i class="bi bi-diagram-3 me-1"></i> Department
                            </label>
                        </div>
                        <div class="col-sm-8">
                            <span class="fw-semibold">
                                @Model.Department?.DepartmentName
                            </span>
                        </div>
                    </div>
                    <hr class="my-2" />

                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <label class="mom-label mb-0">
                                <i class="bi bi-geo-alt me-1"></i> Venue
                            </label>
                        </div>
                        <div class="col-sm-8">
                            <span class="fw-semibold">
                                @Model.MeetingVenue?.MeetingVenueName
                            </span>
                        </div>
                    </div>
                    <hr class="my-2" />

                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <label class="mom-label mb-0">
                                <i class="bi bi-card-text me-1"></i> Description
                            </label>
                        </div>
                        <div class="col-sm-8">
                            @if (!string.IsNullOrWhiteSpace(Model.MeetingDescription))
                            {
                                <p class="mb-0 text-dark">@Model.MeetingDescription</p>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">No description provided</span>
                            }
                        </div>
                    </div>
                    <hr class="my-2" />

                    <div class="row">
                        <div class="col-sm-4">
                            <label class="mom-label mb-0">
                                <i class="bi bi-file-earmark me-1"></i> Document
                            </label>
                        </div>
                        <div class="col-sm-8">
                            @if (!string.IsNullOrWhiteSpace(Model.DocumentPath))
                            {
                                <a href="@Model.DocumentPath" target="_blank" class="text-primary text-decoration-none">
                                    <i class="bi bi-download me-1"></i>
                                    View / Download Document
                                </a>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">No document attached</span>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- SIDE PANEL -->
        <div class="col-md-4">

            <!-- STATUS DETAILS -->
            <div class="mom-card mb-4">
                <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-flag"></i>
                        Status Details
                    </div>
                </div>
                <div class="mom-card-body">
                    <div class="mb-3">
                        <label class="mom-label mb-1">Status</label>
                        <div>
                            @if (Model.IsCancelled)
                            {
                                <span class="badge bg-danger px-3 py-2">Cancelled</span>
                            }
                            else if (Model.MeetingDate > DateTime.Now)
                            {
                                <span class="badge bg-primary px-3 py-2">Upcoming</span>
                            }
                            else
                            {
                                <span class="badge bg-success px-3 py-2">Completed</span>
                            }
                        </div>
                    </div>

                    @if (Model.IsCancelled && Model.CancellationDateTime != null)
                    {
                        <div class="mb-3">
                            <label class="mom-label mb-1">Cancelled On</label>
                            <div class="fw-semibold text-danger">
                                @Model.CancellationDateTime?.ToString("MMM dd, yyyy hh:mm tt")
                            </div>
                        </div>
                    }

                    @if (Model.IsCancelled && !string.IsNullOrWhiteSpace(Model.CancellationReason))
                    {
                        <div class="mb-3">
                            <label class="mom-label mb-1">Cancellation Reason</label>
                            <div class="text-muted">@Model.CancellationReason</div>
                        </div>
                    }
                </div>
            </div>

            <!-- TIMESTAMPS -->
            <div class="mom-card">
                <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-clock-history"></i>
                        Timestamps
                    </div>
                </div>
                <div class="mom-card-body">
                    <div class="mb-3">
                        <label class="mom-label mb-1">Created</label>
                        <div class="fw-semibold">
                            @if (Model.Created != DateTime.MinValue)
                            {
                                @Model.Created.ToString("MMM dd, yyyy hh:mm tt")
                            }
                            else
                            {
                                <span class="text-muted fst-italic">N/A</span>
                            }
                        </div>
                    </div>
                    <div>
                        <label class="mom-label mb-1">Last Modified</label>
                        <div class="fw-semibold">
                            @if (Model.Modified != DateTime.MinValue)
                            {
                                @Model.Modified.ToString("MMM dd, yyyy hh:mm tt")
                            }
                            else
                            {
                                <span class="text-muted fst-italic">N/A</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>

    <!-- QUICK ACTIONS -->
    <div class="mom-card mt-4">
        <div class="mom-card-body py-3">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted">
                    <i class="bi bi-lightning me-1"></i> Quick Actions
                </span>
                <div class="d-flex gap-2">
                    <a asp-action="MeetingAddEdit"
                       asp-route-id="@Model.MeetingID"
                       class="mom-btn-primary btn-sm">
                        <i class="bi bi-pencil"></i>
                        Edit
                    </a>

                    @if (!Model.IsCancelled)
                    {
                        <a asp-action="CancelMeeting"
                           asp-route-id="@Model.MeetingID"
                           class="mom-btn-outline btn-sm"
                           onclick="return confirm('Are you sure you want to cancel this meeting?');">
                            <i class="bi bi-x-circle"></i>
                            Cancel Meeting
                        </a>
                    }

                    <a asp-action="DeleteMeeting"
                       asp-route-id="@Model.MeetingID"
                       class="mom-btn-danger"
                       onclick="return confirm('Are you sure you want to delete this record permanentely?');">
                        <i class="bi bi-trash"></i>
                        Delete
                    </a>
                </div>
            </div>
        </div>
    </div>

</section>
