@{
    ViewData["Title"] = "Schedule New Meeting";
}

<div class="pagetitle">
    <h1>Schedule New Meeting</h1>
    <p>Create and schedule a new organizational meeting</p>

    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Meeting" asp-action="MeetingList">Meetings</a>
            </li>
            <li class="breadcrumb-item active">Schedule</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="mom-form-wrapper">

        <div class="mom-form-card">

            <!-- HEADER -->
            <div class="mom-form-header">
                <i class="bi bi-calendar-plus"></i>
                Schedule New Meeting
            </div>

            <!-- FORM -->
            <form method="post" enctype="multipart/form-data">

                <div class="mom-form-body">

                    <div class="row g-4">

                        <!-- Meeting Type -->
                        <div class="col-md-6">
                            <label class="mom-label">Meeting Type</label>
                            <select class="mom-select">
                                <option value="">-- Select Meeting Type --</option>
                                <option value="7" selected="@((int?)ViewBag.MeetingTypeId == 7)">
                                    Board Meeting
                                </option>
                                <option value="8">Review Meeting</option>
                            </select>
                        </div>

                        <!-- Department -->
                        <div class="col-md-6">
                            <label class="mom-label">Department</label>
                            <select class="mom-select">
                                <option value="">-- Select Department --</option>
                                <option>HR</option>
                                <option>IT</option>
                                <option>Finance</option>
                            </select>
                        </div>

                        <!-- Venue -->
                        <div class="col-md-6">
                            <label class="mom-label">Venue</label>
                            <select class="mom-select">
                                <option value="">-- Select Venue --</option>
                                <option>Conference Room A</option>
                                <option>Board Room</option>
                            </select>
                        </div>

                        <!-- Date & Time -->
                        <div class="col-md-6">
                            <label class="mom-label">Meeting Date & Time</label>
                            <input type="datetime-local" class="mom-input" />
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            <label class="mom-label">Meeting Description</label>
                            <textarea class="mom-textarea"
                                      rows="4"
                                      placeholder="Enter meeting description and agenda"></textarea>
                        </div>

                        <!-- File Upload -->
                        <div class="col-12">
                            <label class="mom-label">Meeting Document (Optional)</label>
                            <input type="file" class="mom-input" />
                            <div class="mom-hint">
                                Upload agenda, minutes, or related documents (PDF, DOC, DOCX – Max 5MB)
                            </div>
                        </div>

                        <!-- Guidelines -->
                        <div class="col-12">
                            <div class="alert alert-info">
                                <strong>Meeting Guidelines:</strong>
                                <ul class="mb-0 mt-2">
                                    <li>Ensure the selected venue is available at the scheduled time</li>
                                    <li>Provide a clear meeting agenda</li>
                                    <li>Upload relevant documents for participants</li>
                                    <li>Consider participant availability before scheduling</li>
                                </ul>
                            </div>
                        </div>

                    </div>

                </div>

                <!-- FOOTER -->
                <div class="mom-form-footer">
                    <a asp-action="MeetingList"
                       class="mom-btn-outline">
                        ← Back to Meetings
                    </a>

                    <button type="submit"
                            class="mom-btn-primary">
                        <i class="bi bi-check-circle"></i> Schedule Meeting
                    </button>
                </div>

            </form>

        </div>

    </div>
</section>
