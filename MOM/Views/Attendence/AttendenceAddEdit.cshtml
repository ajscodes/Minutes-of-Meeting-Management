@model MOM.Models.MeetingMember

@{
    ViewData["Title"] = Model.MeetingMemberID == 0 ? "Mark Attendance" : "Edit Attendance";
}

<!-- PAGE TITLE -->
<div class="pagetitle mb-4">
    <h1 class="fw-bold">@ViewData["Title"]</h1>
    <p class="text-muted mb-2">
        @(Model.MeetingMemberID == 0 ? "Add new member attendance for a meeting." : "Modify existing attendance details.")
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="AttendenceList">Attendance</a>
            </li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row min-vh-100 align-items-start pt-4">

        <div class="col-12 col-xl-8 mx-auto">
            <div class="mom-card w-100">
                <!-- Header -->
                <div class="mom-card-header d-flex align-items-center gap-2">
                    <i class="bi bi-person-check fs-5 text-primary"></i>
                    <h5 class="mom-card-title mb-0">
                        @(Model.MeetingMemberID == 0 ? "New Attendance Entry" : "Edit Details")
                    </h5>
                </div>

                <div class="mom-card-body p-4 p-md-5">

                    <form asp-action="AttendenceAddEdit" method="post">
                        <!-- ID FIELD (HIDDEN) -->
                        <input type="hidden" asp-for="MeetingMemberID" />

                        <!-- MEETING SECTION -->
                        <div class="row mb-4">
                            <label class="col-sm-4 col-form-label mom-label">
                                Meeting <span class="text-danger">*</span>
                            </label>
                            <div class="col-sm-8 text-start">
                                <select asp-for="MeetingID"
                                        class="form-select border-1"
                                        asp-items="@ViewBag.Meetings">
                                    <option value="">Select Meeting</option>
                                </select>
                                <span asp-validation-for="MeetingID" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- STAFF MEMBER SECTION -->
                        <div class="row mb-4">
                            <label class="col-sm-4 col-form-label mom-label">
                                Staff Member <span class="text-danger">*</span>
                            </label>
                            <div class="col-sm-8 text-start">
                                <select asp-for="StaffID"
                                        class="form-select border-1"
                                        asp-items="@ViewBag.Staffs">
                                    <option value="">Select Staff</option>
                                </select>
                                <span asp-validation-for="StaffID" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- IS PRESENT -->
                        <div class="row align-items-center mb-4">
                            <label class="col-sm-4 col-form-label mom-label mb-0">
                                Attendance Status
                            </label>
                            <div class="col-sm-8 text-start">
                                <div class="form-check form-switch mom-switch mt-1">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           asp-for="IsPresent"
                                           id="switchIsPresent">
                                    <label class="form-check-label text-muted small ms-2" for="switchIsPresent">
                                        Mark as Present
                                    </label>
                                </div>
                                <span asp-validation-for="IsPresent" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- REMARKS -->
                        <div class="row mb-5">
                            <label class="col-sm-4 col-form-label mom-label">
                                Remarks
                            </label>
                            <div class="col-sm-8 text-start">
                                <textarea asp-for="Remarks"
                                          class="form-control"
                                          rows="3"
                                          placeholder="Enter any relevant observations..."></textarea>
                                <span asp-validation-for="Remarks" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- FORM ACTIONS -->
                        <div class="row mt-4 pt-3 border-top">
                            <div class="col-sm-8 offset-sm-4 text-start">
                                <button type="submit" class="mom-btn-primary px-4 me-2">
                                    <i class="bi bi-save me-1"></i>
                                    Save Record
                                </button>
                                <a asp-action="AttendenceList" class="mom-btn-outline px-4">
                                    Cancel
                                </a>
                            </div>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
