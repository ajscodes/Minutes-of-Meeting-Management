@model List<MOM.Models.MeetingMember>

@{
    ViewData["Title"] = "Attendance Management";
}

<!-- PAGE TITLE -->
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Attendance Management</h1>
    <p class="text-muted mb-2">
        Manage attendance and marks for meeting members.
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active">Attendance</li>
        </ol>
    </nav>
</div>

<!-- SUCCESS / ERROR MESSAGES -->
@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 border-start border-danger border-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill text-danger me-2 fs-5"></i>
            <div>@TempData["Error"]</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="section">

    <!-- TOP ACTION BAR -->
    <div class="d-flex justify-content-end gap-2 mb-4">
        <a asp-action="AttendenceAddEdit" class="mom-btn-primary">
            <i class="bi bi-plus-circle"></i>
            Mark Attendance
        </a>
    </div>

    <!-- ATTENDANCE LIST -->
    <div class="mom-card">
        <div class="mom-card-header d-flex justify-content-between align-items-center">
            <div class="mom-card-title">
                <i class="bi bi-person-check"></i>
                Meeting Members
            </div>

            <span class="badge bg-light text-dark">
                Total: @(Model?.Count ?? 0)
            </span>
        </div>

        <div class="mom-card-body p-0">
            <table class="table mom-table align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:50px">#</th>
                        <th>Meeting Date</th>
                        <th>Staff Name</th>
                        <th class="text-center">Present</th>
                        <th>Remarks</th>
                        <th style="width:140px" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int index = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">@index</td>

                                <td>
                                    @if(item.Meeting != null)
                                    {
                                        <div class="fw-semibold text-dark">
                                            @item.Meeting.MeetingDate.ToString("MMM dd, yyyy")
                                        </div>
                                    }
                                </td>

                                <td>
                                    @if(item.Staff != null)
                                    {
                                        <div class="fw-semibold text-primary">
                                            @item.Staff.StaffName
                                        </div>
                                    }
                                </td>

                                <td class="text-center">
                                    @if (item.IsPresent)
                                    {
                                        <span class="badge bg-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">No</span>
                                    }
                                </td>

                                <td class="text-muted text-truncate" style="max-width: 200px;">
                                    @item.Remarks
                                </td>

                                <!-- Actions -->
                                <td class="text-center">
                                    <div class="d-inline-flex gap-2">
                                        <!-- Edit -->
                                        <a asp-action="AttendenceAddEdit"
                                           asp-route-id="@item.MeetingMemberID"
                                           class="mom-icon-btn text-warning"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <!-- Delete -->
                                        <a asp-action="DeleteAttendence"
                                           asp-route-id="@item.MeetingMemberID"
                                           class="mom-icon-btn text-danger"
                                           title="Delete Record"
                                           onclick="return confirm('Are you sure you want to delete this attendance record permanentely?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No attendance records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
