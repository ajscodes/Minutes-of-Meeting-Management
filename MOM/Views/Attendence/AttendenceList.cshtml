@model List<MOM.Models.MeetingMember>

@{
    ViewData["Title"] = "Attendance Report";
    
    int totalRecords = Model?.Count ?? 0;
    int presentRecords = Model?.Count(m => m.IsPresent) ?? 0;
    double attendanceRate = totalRecords > 0 ? Math.Round((double)presentRecords * 100 / totalRecords, 1) : 0;
    int uniqueMeetings = Model?.Select(m => m.MeetingID).Distinct().Count() ?? 0;
}

<!-- PAGE TITLE -->
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Attendance Report</h1>
    <p class="text-muted mb-2">
        Generate and export attendance reports
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active">Attendance Report</li>
        </ol>
    </nav>
</div>

<section class="section">

    <!-- REPORT FILTERS -->
    <div class="mom-card mb-4">
        <div class="mom-card-header d-flex justify-content-between align-items-center">
            <div class="mom-card-title">
                <i class="bi bi-funnel"></i>
                Report Filters
            </div>
        </div>
        <div class="mom-card-body pt-4">
            <form method="get" asp-action="AttendenceList">
                <div class="row align-items-end g-4">
                    <div class="col-md-4">
                        <label class="mom-label mb-2">Start Date</label>
                        <div class="input-group">
                            <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="mom-label mb-2">End Date</label>
                        <div class="input-group">
                            <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                        </div>
                    </div>
                    <div class="col-md-4 d-flex gap-3">
                        <button type="submit" class="mom-btn-primary flex-grow-1">
                            <i class="bi bi-search me-1"></i> Generate Report
                        </button>
                        <button type="button" class="mom-btn-outline">
                            <i class="bi bi-download me-1"></i> Export
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- SUMMARY CARDS -->
    <div class="row mb-5 g-4 mt-1">
        <div class="col-md-3">
            <div class="mom-card text-start py-4 px-4 h-100 border-0 shadow-sm rounded-4">
                <div class="text-primary text-uppercase mb-2" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">TOTAL RECORDS</div>
                <div class="fs-4 fw-bold text-dark">@totalRecords</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="mom-card text-start py-4 px-4 h-100 border-0 shadow-sm rounded-4">
                <div class="text-success text-uppercase mb-2" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">PRESENT</div>
                <div class="fs-4 fw-bold text-dark">@presentRecords</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="mom-card text-start py-4 px-4 h-100 border-0 shadow-sm rounded-4">
                <div class="text-warning text-uppercase mb-2" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">ATTENDANCE RATE</div>
                <div class="fs-4 fw-bold text-dark">@attendanceRate%</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="mom-card text-start py-4 px-4 h-100 border-0 shadow-sm rounded-4">
                <div class="text-info text-uppercase mb-2" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">UNIQUE MEETINGS</div>
                <div class="fs-4 fw-bold text-dark">@uniqueMeetings</div>
            </div>
        </div>
    </div>

    <!-- DATA TABLE -->
    <div class="mom-card">
        <div class="mom-card-header d-flex justify-content-between align-items-center">
            <div class="mom-card-title m-0">
                <i class="bi bi-grid-3x3-gap-fill"></i> 
                Attendance Data 
                <span class="badge bg-primary ms-2 rounded-pill">@totalRecords records</span>
            </div>
            <a asp-action="AttendenceList" class="mom-btn-outline" style="padding: 6px 12px; font-size: 13px;">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
        <div class="mom-card-body p-0">
            <table class="table mom-table align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:50px">#</th>
                        <th style="width:140px">Date</th>
                        <th>Meeting Type</th>
                        <th>Department</th>
                        <th>Staff Name</th>
                        <th>Staff Email</th>
                        <th class="text-center">Attendance</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int index = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">@index</td>

                                <td>
                                    @if (item.Meeting != null)
                                    {
                                        <div class="fw-semibold text-dark">
                                            @item.Meeting.MeetingDate.ToString("MMM dd, yyyy")
                                        </div>
                                        <div class="text-muted small">
                                            @item.Meeting.MeetingDate.ToString("hh:mm tt")
                                        </div>
                                    }
                                </td>

                                <td>
                                    <div class="fw-semibold text-primary">
                                        @(item.Meeting?.MeetingType?.MeetingTypeName ?? "-")
                                    </div>
                                </td>

                                <td>@(item.Staff?.Department?.DepartmentName ?? "-")</td>

                                <td>
                                    <div class="fw-semibold text-dark">
                                        @(item.Staff?.StaffName ?? "-")
                                    </div>
                                </td>

                                <td>
                                    @if (!string.IsNullOrEmpty(item.Staff?.Email))
                                    {
                                        <a href="mailto:@item.Staff.Email" class="text-decoration-none">
                                            @item.Staff.Email
                                        </a>
                                    }
                                    else
                                    {
                                        @("-")
                                    }
                                </td>

                                <td class="text-center">
                                    @if (item.IsPresent)
                                    {
                                        <span class="badge bg-success">Present</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Absent</span>
                                    }
                                </td>
                            </tr>
                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-2 mb-3 d-block"></i>
                                No attendance data matching filters.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
