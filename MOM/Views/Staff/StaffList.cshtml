@model List<MOM.Models.Staff>

@{
    ViewData["Title"] = "Staff Members";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- PAGE TITLE -->
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Staff Members</h1>
    <p class="text-muted mb-2">
        Manage staff members and their meeting participation
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active">Staff Members</li>
        </ol>
    </nav>
</div>

<section class="section">

    <!-- TOP ACTION BAR -->
    <div class="d-flex justify-content-end gap-2 mb-4">
        <a asp-action="StaffAddEdit"
           asp-route-departmentId="0"
           class="mom-btn-primary">
            <i class="bi bi-person-plus"></i>
            Add Staff Member
        </a>

        <a href="#" class="mom-btn-outline">
            <i class="bi bi-file-earmark-excel"></i>
            Export
        </a>
    </div>

    <!-- FILTER & SEARCH -->
    <div class="mom-card mb-4">
        <div class="mom-card-body py-3">
            <form method="post" asp-action="StaffList" asp-controller="Staff">
                <div class="row g-2 align-items-center">

                    <!-- DEPARTMENT FILTER -->
                    <div class="col-md-4">
                        <div class="mom-search-input">
                             <!-- Using mom-select style manually for consistency -->
                             <i class="bi bi-funnel"></i>
                             <select class="mom-select" style="padding-left: 45px; height: 48px;" name="departmentId">
                                <option value="0">All Departments</option>
                                @if (ViewBag.Departments != null)
                                {
                                    foreach (var dept in ViewBag.Departments)
                                    {
                                        if (ViewBag.DepartmentId != null && ViewBag.DepartmentId.ToString() == dept.Value)
                                        {
                                            <option value="@dept.Value" selected>@dept.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@dept.Value">@dept.Text</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <!-- SEARCH INPUT -->
                    <div class="col-md-5">
                        <div class="mom-search-input">
                            <i class="bi bi-search"></i>
                            <input type="text"
                                   name="SearchText"
                                   id="SearchText"
                                   class="form-control"
                                   placeholder="Search staff..."
                                   value="@ViewBag.SearchText" />
                        </div>
                    </div>

                    <!-- ACTIONS -->
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="mom-btn-primary w-100">
                            Apply
                        </button>
                        <a asp-action="StaffList" asp-route-departmentId="0" class="mom-btn-outline w-100">
                            Clear
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- STAFF LIST -->
    <div class="mom-card">
        <div class="mom-card-header d-flex justify-content-between align-items-center">
            <div class="mom-card-title">
                <i class="bi bi-people"></i>
                Staff Members List
            </div>

            <span class="badge bg-light text-dark">
                Total: @Model.Count
            </span>
        </div>

        <div class="mom-card-body p-0">
            <table class="table mom-table align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Staff Name</th>
                        <th>Department</th>
                        <th>Mobile</th>
                        <th>Email Address</th>
                        <th style="width:130px">Total Meetings</th>
                        <th style="width:130px">Attendance</th>
                        <th style="width:130px">Created Date</th>
                        <th style="width:140px" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Any())
                    {
                        int index = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">@index</td>

                                <!-- NAME -->
                                <td class="fw-semibold text-primary">
                                    @item.StaffName
                                </td>

                                <!-- DEPARTMENT -->
                                <td>
                                    <span class="mom-badge mom-badge-primary">@item.Department.DepartmentName</span>
                                </td>


                                <!-- MOBILE -->
                                <td>
                                    @item.Mobile
                                </td>


                                <!-- EMAIL -->
                                <td>
                                    <a href="mailto:@item.Email" class="text-decoration-none">
                                        @item.Email
                                    </a>
                                </td>


                                <!-- TOTAL MEETINGS (STATIC FOR NOW) -->
                                <td>
                                    <span class="badge bg-secondary">0</span>
                                </td>

                                <!-- ATTENDANCE (STATIC FOR NOW) -->
                                <td>
                                    <span class="badge bg-success">0%</span>
                                </td>

                                <!-- CREATED -->
                                <td>
                                    @item.Created.ToString("dd MMM yyyy")
                                </td>

                                <!-- ACTIONS -->
                                <td class="text-center">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="StaffDetails"
                                           asp-route-id="@item.StaffID"
                                           class="mom-icon-btn text-info"
                                           title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="StaffAddEdit"
                                           asp-route-id="@item.StaffID"
                                           class="mom-icon-btn text-warning"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a asp-action="StaffDelete"
                                           asp-route-id="@item.StaffID"
                                           asp-route-departmentId="@item.DepartmentID"
                                           class="mom-icon-btn text-danger"
                                           title="Delete"
                                           onclick="return confirm('Are you sure you want to delete this staff member?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9"
                                class="text-center text-muted py-4">
                                No staff members found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</section>
