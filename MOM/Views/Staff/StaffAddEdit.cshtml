@model MOM.Models.Staff

@{
    bool isEdit = Model.StaffID > 0;
    ViewData["Title"] = isEdit ? "Edit Staff Member" : "Add Staff Member";
    var departmentName = ViewBag.DepartmentName as string ?? "Department";
}

<div class="pagetitle">
    <h1>@ViewData["Title"]</h1>
    <p>@departmentName Department</p>
</div>

<section class="section">
    <div class="mom-form-wrapper">

        <div class="mom-form-card">

            <div class="mom-form-header">
                <i class="bi bi-person-plus"></i>
                @ViewData["Title"]
            </div>

            <form asp-action="StaffAddEdit" method="post">
                <input type="hidden" asp-for="StaffID" />


                <div class="mom-form-body">

                    <!-- Staff Name -->
                    <div class="mb-4">
                        <label asp-for="StaffName" class="mom-label">Staff Name <span class="text-danger">*</span></label>
                        <input asp-for="StaffName"
                               class="mom-input"
                               placeholder="Enter staff full name" />
                        <span asp-validation-for="StaffName" class="text-danger small"></span>
                    </div>

                    <!-- Department -->
                    <div class="mb-4">
                        <label asp-for="DepartmentID" class="mom-label">Department <span class="text-danger">*</span></label>
                        <select asp-for="DepartmentID"
                                asp-items="ViewBag.Departments"
                                class="mom-input"
                                required>
                            <option value="">-- Select Department --</option>
                        </select>
                        <span asp-validation-for="DepartmentID" class="text-danger small"></span>
                    </div>

                    <!-- Mobile -->
                    <div class="mb-4">
                        <label asp-for="Mobile" class="mom-label">Mobile Number</label>
                        <input asp-for="Mobile"
                               class="mom-input"
                               placeholder="e.g. 9876543210" />
                        <span asp-validation-for="Mobile" class="text-danger small"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-4">
                        <label asp-for="Email" class="mom-label">Email Address</label>
                        <input asp-for="Email"
                               class="mom-input"
                               placeholder="e.g. user@company.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Remarks -->
                    <div class="mb-4">
                        <label asp-for="Remarks" class="mom-label">Remarks</label>
                        <textarea asp-for="Remarks"
                                  class="mom-textarea"
                                  rows="3"
                                  placeholder="Role or remarks"></textarea>
                        <span asp-validation-for="Remarks" class="text-danger small"></span>
                    </div>

                </div>

                <div class="mom-form-footer">
                    <a asp-action="StaffList"
                       asp-route-departmentId="@Model.DepartmentID"
                       class="mom-btn-outline">
                        ? Back to List
                    </a>

                    <button type="submit"
                            class="mom-btn-primary">
                        <i class="bi bi-check-circle"></i> @(isEdit ? "Update Staff" : "Add Staff")
                    </button>
                </div>

            </form>

        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
