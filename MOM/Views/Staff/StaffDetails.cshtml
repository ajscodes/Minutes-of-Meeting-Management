@model MOM.Models.Staff

@{
    ViewData["Title"] = "Staff Details";
}

<div class="pagetitle mb-4">
    <h1 class="fw-bold">@ViewData["Title"]</h1>
    <p class="text-muted mb-0">
        Detailed information about staff member
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="StaffList" asp-route-departmentId="@Model.DepartmentID">Staff Members</a>
            </li>
            <li class="breadcrumb-item active">Details</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        
        <!-- LEFT: Staff Info -->
        <div class="col-lg-8">
            <div class="mom-card mb-4">
                <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-person-lines-fill"></i>
                        Staff Information
                    </div>
                     <a asp-action="StaffAddEdit"
                       asp-route-id="@Model.StaffID"
                       asp-route-departmentId="@Model.DepartmentID"
                       class="mom-btn-outline"
                       style="padding: 6px 12px; font-size: 13px;">
                        <i class="bi bi-pencil"></i> Edit Profile
                    </a>
                </div>

                <div class="mom-card-body">
                    <div class="mom-info-grid">
                        
                        <div class="mom-label">Full Name</div>
                        <div class="mom-value text-primary fs-5">@Model.StaffName</div>

                        <div class="mom-label">Department</div>
                        <div class="mom-value">
                            <span class="mom-badge mom-badge-primary">
                                @(Model.Department?.DepartmentName ?? "-")
                            </span>
                        </div>

                        <div class="mom-label">Email Address</div>
                        <div class="mom-value">
                            <a href="mailto:@Model.Email" class="text-decoration-none">
                                @Model.Email
                            </a>
                        </div>

                        <div class="mom-label">Mobile Number</div>
                        <div class="mom-value">@Model.Mobile</div>

                        <div class="mom-label">Joined Date</div>
                        <div class="mom-value">@Model.Created.ToString("dd MMM yyyy")</div>
                        
                        <div class="mom-label">Role / Remarks</div>
                        <div class="mom-value text-muted fst-italic">
                            @(string.IsNullOrEmpty(Model.Remarks) ? "No remarks available." : Model.Remarks)
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Stats & Activity -->
        <div class="col-lg-4">
            
            <!-- Statistics -->
            <div class="mom-card mb-4">
                <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-activity"></i>
                        Participation Stats
                    </div>
                </div>
                <div class="mom-card-body">
                    <div class="row text-center">
                        <div class="col-6 mb-3">
                            <div class="mom-stat-value text-primary">12</div>
                            <div class="mom-stat-label">Meetings</div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="mom-stat-value text-success">92%</div>
                            <div class="mom-stat-label">Attendance</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Card -->
            <div class="mom-card">
                 <div class="mom-card-header">
                    <div class="mom-card-title">
                        <i class="bi bi-chat-left-text"></i>
                        Quick Contact
                    </div>
                </div>
                <div class="mom-card-body d-grid gap-2">
                    <a href="mailto:@Model.Email" class="mom-btn-outline w-100 justify-content-center">
                        <i class="bi bi-envelope"></i> Send Email
                    </a>
                    <a href="tel:@Model.Mobile" class="mom-btn-outline w-100 justify-content-center">
                        <i class="bi bi-telephone"></i> Call Staff
                    </a>
                </div>
            </div>

        </div>

    </div>
</section>
