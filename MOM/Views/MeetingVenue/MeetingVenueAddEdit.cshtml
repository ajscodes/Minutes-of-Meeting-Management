@model MOM.Models.MeetingVenue

@{
    bool isEdit = Model != null && Model.MeetingVenueID > 0;
    ViewData["Title"] = isEdit ? "Edit Meeting Venue" : "Add Meeting Venue";
}

<div class="pagetitle">
    <h1>@ViewData["Title"]</h1>
    <p>Configure meeting rooms or venues</p>
</div>

<section class="section">
    <div class="mom-form-wrapper">

        <div class="mom-form-card">

            <div class="mom-form-header">
                <i class="bi bi-geo-alt"></i>
                @ViewData["Title"]
            </div>

            <form asp-action="MeetingVenueAddEdit" method="post">
                <input type="hidden" asp-for="MeetingVenueID" />

                <div class="mom-form-body">

                    <!-- Venue Name -->
                    <div class="mb-4">
                        <label asp-for="MeetingVenueName" class="mom-label">Venue Name <span class="text-danger">*</span></label>
                        <input asp-for="MeetingVenueName"
                               class="mom-input"
                               placeholder="e.g. Conference Room A, Zoom Room" />
                        <span asp-validation-for="MeetingVenueName" class="text-danger small"></span>
                    </div>

                </div>

                <div class="mom-form-footer">
                    <a asp-action="MeetingVenueList"
                       class="mom-btn-outline">
                        ← Back to List
                    </a>

                    <button type="submit"
                            class="mom-btn-primary">
                        <i class="bi bi-check-circle"></i> @(isEdit ? "Update Venue" : "Add Venue")
                    </button>
                </div>

            </form>

        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
