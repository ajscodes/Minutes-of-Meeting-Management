@model MOM.Models.MeetingVenue

@{
    bool isEdit = Model != null && Model.MeetingVenueID > 0;
    ViewData["Title"] = isEdit ? "Edit Meeting Venue" : "Add Meeting Venue";
}


<div class="pagetitle mb-4">
    <h1 class="mb-1">@ViewData["Title"]</h1>
    <p class="text-muted mb-0">
        Configure meeting rooms or venues
    </p>
</div>

<section class="section">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-geo-alt"></i>
                        @ViewData["Title"]
                    </h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="MeetingVenueAddEdit" method="post">

                        <input type="hidden" asp-for="MeetingVenueID" />

                        <!-- Venue Name -->
                        <div class="mb-3">
                            <label asp-for="MeetingVenueName"
                                   class="form-label fw-semibold">
                                Venue Name <span class="text-danger">*</span>
                            </label>

                            <input asp-for="MeetingVenueName"
                                   class="form-control"
                                   placeholder="e.g. Conference Room A, Zoom Room" />

                            <span asp-validation-for="MeetingVenueName"
                                  class="text-danger small"></span>
                        </div>


                        <!-- Actions -->
                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="MeetingVenueList"
                               class="btn btn-light">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>

                            <button type="submit"
                                    class="btn btn-primary px-4">
                                <i class="bi bi-check-circle"></i>
                                @(isEdit ? "Update Venue" : "Add Venue")
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
