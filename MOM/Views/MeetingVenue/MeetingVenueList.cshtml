@model List<MOM.Models.MeetingVenue>

@{
    ViewData["Title"] = "Meeting Venues";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- PAGE TITLE -->
<div class="pagetitle mb-4">
    <h1 class="fw-bold">Meeting Venues</h1>
    <p class="text-muted mb-2">
        Manage meeting rooms and venues
    </p>

    <nav>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active">Meeting Venues</li>
        </ol>
    </nav>
</div>

<section class="section">

    <!-- TOP ACTION BAR -->
    <div class="d-flex justify-content-end gap-2 mb-4">
        <a asp-action="MeetingVenueAddEdit" class="mom-btn-primary">
            <i class="bi bi-plus-circle"></i>
            Add New Venue
        </a>

        <a href="#" class="mom-btn-outline">
            <i class="bi bi-file-earmark-excel"></i>
            Export
        </a>
    </div>

    <!-- SEARCH -->
    <div class="mom-card mb-4">
        <div class="mom-card-body py-3">
            <form method="post" asp-action="MeetingVenueList" asp-controller="MeetingVenue">
                <div class="row g-2 align-items-center">

                    <!-- SEARCH INPUT -->
                    <div class="col-md-7">
                        <div class="mom-search-input">
                            <i class="bi bi-search"></i>
                            <input type="text"
                                   name="SearchText"
                                   id="SearchText"
                                   class="form-control"
                                   placeholder="Search venue..."
                                   value="@ViewBag.SearchText" />
                        </div>
                    </div>

                    <!-- SEARCH BUTTON -->
                    <div class="col-md-3">
                        <button type="submit" class="mom-btn-primary w-100">
                            Search
                        </button>
                    </div>

                    <!-- CLEAR BUTTON -->
                    <div class="col-md-2">
                        <a asp-action="MeetingVenueList"
                           class="mom-btn-outline w-100">
                            Clear
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>


    <!-- LIST -->
    <div class="mom-card">
        <div class="mom-card-header d-flex justify-content-between align-items-center">
            <div class="mom-card-title">
                <i class="bi bi-geo-alt"></i>
                Venue List
            </div>

            <span class="badge bg-light text-dark">
                Total Records: @Model.Count
            </span>
        </div>

        <div class="mom-card-body p-0">
            <table class="table mom-table align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Venue Name</th>
                        <th style="width:130px">Created</th>
                        <th style="width:130px">Modified</th>
                        <th style="width:120px" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Any())
                    {
                        int index = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">@index</td>

                                <td class="fw-semibold text-primary">
                                    @item.MeetingVenueName
                                </td>

                                <td>
                                    @item.Created.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    @item.Modified.ToString("dd MMM yyyy")
                                </td>

                                <td class="text-center">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="MeetingVenueAddEdit"
                                           asp-route-id="@item.MeetingVenueID"
                                           class="mom-icon-btn text-warning"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <!-- Note: Delete action requires backend implementation -->
                                        <a asp-controller="MeetingVenue"
                                           asp-action="MeetingVenueDelete"
                                           asp-route-id="@item.MeetingVenueID"
                                           class="mom-icon-btn text-danger"
                                           title="Delete"
                                           onclick="return confirm('Are you sure you want to delete this venue?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4"
                                class="text-center text-muted py-4">
                                No meeting venues available.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</section>
