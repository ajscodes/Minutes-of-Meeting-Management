@model List<MOM.Models.MeetingVenue>

@{
    ViewData["Title"] = "Meeting Venues";
}

<div class="pagetitle d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Meeting Venues</h1>
        <p class="text-muted mb-0">
            Manage meeting rooms and venues
        </p>
    </div>

    <a asp-controller="MeetingVenue"
       asp-action="MeetingVenueAddEdit"
       class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Venue
    </a>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <strong>Venue List</strong>
                </div>

                <div class="card-body">

                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-info text-center mb-0">
                            No meeting venues available.
                        </div>
                    }
                    else
                    {
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:5%">#</th>
                                    <th>Venue Name</th>
                                    <th style="width:20%">Created</th>
                                    <th style="width:15%" class="text-center">Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int srNo = 1;
                                }

                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@srNo</td>

                                        <td class="fw-semibold">
                                            @item.MeetingVenueName
                                        </td>
                          

                                        <td>
                                            @item.Created.ToString("yyyy-MM-dd")
                                        </td>

                                        <td class="text-center">
                                            <a asp-action="MeetingVenueAddEdit"
                                               asp-route-id="@item.MeetingVenueID"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </td>
                                    </tr>

                                    srNo++;
                                }
                            </tbody>
                        </table>
                    }

                </div>
            </div>

        </div>
    </div>
</section>
